# Copy this to a .env file and fill in values as needed
# This is the minimal config for running on Kaggle with Ollama + Gemma

# --- LLM CONFIGURATION ---
# Default: local Ollama (set up in the Kaggle notebook)
USE_REMOTE_MODEL=0
MODEL_OLLAMA=gemma4:e2b
OLLAMA_ENDPOINT=http://localhost:11434/api/chat

# Optional: Remote model server (if you run a separate Kaggle notebook with Ngrok)
# USE_REMOTE_MODEL=1
# GEMMA_API_URL=https://your-ngrok-url.ngrok-free.dev

# --- API KEYS (Only needed for Gemini/NVIDIA fallbacks, not used with Ollama) ---
# GEMINI_API_KEY=your_gemini_api_key_here
# NVIDIA_API_KEY=your_nvapi_key_here

# --- MLOps TRACKING (Optional) ---
# WANDB_API_KEY=your_wandb_api_key_here
